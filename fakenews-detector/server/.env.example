# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/fakenews-detector

# Server Port
PORT=5000

# Ollama (local LLaMA 3) — default endpoint
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Groq API (fallback if Ollama is slow/unavailable)
# Get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# NewsAPI — https://newsapi.org (free tier: 100 req/day)
NEWS_API_KEY=your_newsapi_key_here

# Tavily API — https://tavily.com (AI-optimized search, free tier)
TAVILY_API_KEY=your_tavily_api_key_here

# Which LLM provider to use: "ollama" or "groq"
LLM_PROVIDER=ollama

# CORS — frontend URL
CLIENT_URL=http://localhost:5173
